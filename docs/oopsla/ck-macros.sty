\RequirePackage{xparse}


%% COLOURS
\NewDocumentCommand{\Conf}{m}{{\color{DeeperBlue} #1}}
\NewDocumentCommand{\Machine}{m}{{\color{DogwoodRose} #1}}


%% MACHINES
\NewDocumentCommand{\CKMachine}{mm}{\Machine{\DelimGl{\CTerm{#1},\; \Stk{#2}}}}
\NewDocumentCommand{\LMachine}{O{\Gamma}mm}{%
  \Machine{#1%
    .
%   \raisebox{-0.08ex}{\scalebox{0.3}{$\blacksquare$}}%
  \DelimGl{\CTerm{#2},\; \Stk{#3}}}
}
\NewDocumentCommand{\SLMachine}{O{\Gamma}mO{S}m}{\Machine{#1.\DelimGl{\CTerm{#2},\; \Susp{#3},\; \Stk{#4}}}}

\NewDocumentCommand{\MStep}{}{\rightsquigarrow}
\NewDocumentCommand{\MSteps}{mm}{\Machine{#1} \mathrel{\MStep} \Conf{#2}}
\NewDocumentCommand{\MStepMany}{}{\MStep^\ast}
\NewDocumentCommand{\MStepsMany}{mm}{\Machine{#1} \mathrel{\MStepMany} \Machine{#2}}
\NewDocumentCommand{\NotMStepsMany}{mm}{\Machine{#1} \not \mathrel{\MStepMany} \Machine{#2}}

\NewDocumentCommand{\CStep}{}{\Rrightarrow}
\NewDocumentCommand{\CSteps}{mm}{\Conf{#1} \mathrel{\CStep} \Conf{#2}}
\NewDocumentCommand{\CStepsN}{mmm}{\Conf{#2} \CStep^{#1} \Conf{#3}}

\NewDocumentCommand{\DDStep}{}{\rightharpoonup}
\NewDocumentCommand{\DDSteps}{mm}{\Machine{#1} \mathrel{\DDStep} \Machine{#2}}
\NewDocumentCommand{\DDStepsMany}{mm}{\Machine{#1} \mathrel{\DDStep^\ast} \Machine{#2}}
\NewDocumentCommand{\NotDDStepsMany}{mm}{\Machine{#1} \not \mathrel{\DDStep^\ast} \Machine{#2}}

\NewDocumentCommand{\StkEmpty}{}{\Stk{\odot}}
\NewDocumentCommand{\StkKont}{mmm}{%
  \Stk{
    \textsf{to}\ #1.\, \CTerm{#2} :: #3
  }%
}
\NewDocumentCommand{\StkVal}{mm}{%
  \VTerm{#1}\ \Stk{:: #2}%
}
\NewDocumentCommand{\StkConcat}{mm}{
  \Stk{#1} \ \color{CommandPurple}{++} \ \Stk{#2}
}

\NewDocumentCommand{\StartConf}{m}{\LMachine[]{#1}{\StkEmpty}}
\NewDocumentCommand{\FinalConf}{O{\Gamma}m}{\LMachine[#1]{\Return{#2}}{\StkEmpty}}

\NewDocumentCommand{\ConfResults}{m}{\textsf{results}(\Conf{#1})}
\NewDocumentCommand{\Results}{m}{\textsf{results}(\CTerm{#1})}

\NewDocumentCommand{\LEnvEmpty}{}{[\cdot]}
\NewDocumentCommand{\LEnvExt}{mmmm}{#1\DelimBrk{#2 \mapsto (#3, #4)}}
\NewDocumentCommand{\LEnvSet}{mmmm}{#1\DelimBrk{#2 \coloneqq \VTerm{#4}}}

\NewDocumentCommand{\FailC}{}{\Conf{\textsf{fail}}}
\NewDocumentCommand{\ChoiceC}{smm}{
  \IfBooleanTF{#1}{
    \DelimPrn{\Conf{#2} \mathbin{\Conf{\talloblong}} \Conf{#3}}
  }{
    \Conf{#2} \mathbin{\Conf{\talloblong}} \Conf{#3}
  }
}

\NewDocumentCommand{\KSubst}{smmm}{%
  \IfBooleanTF{#1}{\DelimBrk{\Stk{#2}}}{\Stk{#2}}\Meta{[\VTerm{#3}/\VTerm{#4}]}
}

\NewDocumentCommand{\SEquiv}{mm}{\Conf{#1} \equiv \Conf{#2}}

\NewDocumentCommand{\Susp}{m}{{\color{purple} #1}}
\NewDocumentCommand{\SuspEmpty}{}{}
\NewDocumentCommand{\AddSusp}{mmm}{\Susp{#1{\color{black} \DelimBrk{#2 \mapsto \CTerm{#3}}}}}
\NewDocumentCommand{\DisjSusp}{mmm}{\Susp{#1{\color{black} \mathbin{\otimes} \DelimBrk{#2 \mapsto \CTerm{#3}}}}}

\NewDocumentCommand{\IsStk}{O{\Gamma}mmm}{#1 \vdash \Stk{#2} : #3 \multimap #4}

% Translating configurations to computations

\NewDocumentCommand{\TransConf}{m}{\CTerm{\llparenthesis\, \Conf{#1}\, \rrparenthesis}}

\NewDocumentCommand{\IsTyConf}{mm}{\vdash \Conf{#1} : #2}

% Substitutions

\NewDocumentCommand{\MSubst}{smmm}{%
  \IfBooleanTF{#1}{\DelimPrn{\Machine{#2}}}{\Machine{#2}}\Meta{[\VTerm{#3}/\VTerm{#4}]}
}

\NewDocumentCommand{\SimSubM}{smm}{%
  \IfBooleanTF{#1}{\DelimPrn{\Machine{#2}}}{\Machine{#2}}\Meta{\DelimBrc{#3}}
}
\NewDocumentCommand{\SimSubK}{smm}{%
  \IfBooleanTF{#1}{\DelimPrn{\Stk{#2}}}{\Stk{#2}}\Meta{\DelimBrk{#3}}
}

\NewDocumentCommand{\IsLeaf}{mm}{\Machine{#1} \mathrel{\unlhd} \Conf{#2} }
