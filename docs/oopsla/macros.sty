%% MACROS LOCAL TO THIS ARTICLE GO IN THIS FILE

\RequirePackage{cbpv}

%% BASIC THINGS

\NewDocumentCommand{\ValU}{m}{\mathfrak{V}_{#1}}
\NewDocumentCommand{\Monad}{sg}{
  T\IfNoValueTF{#2}{}{
    \IfBooleanTF{#1}{\DelimPrn{#2}}{#2}
  }
}

%% FLP EFFECTS

\NewDocumentCommand{\Fail}{o}{%
 \textsf{fail}_{\IfNoValueTF{#1}{}{#1}}%
}

\NewDocumentCommand{\Choice}{omm}{%
  #2%
  \IfNoValueTF{#1}{\talloblong}{\talloblong_{#1}}%
  #3%
}

\NewDocumentCommand{\Exists}{smom}{%
  \exists%
  \IfNoValueTF{#3}{#2}{\DeclVar{#2}{#3}}%
  .\,%
  \IfBooleanTF{#1}{\DelimPrn{#4}}{#4}%
}

\NewDocumentCommand{\Equate}{mmom}{%
  \VTerm{#1}%
  \mathbin{\IfNoValueTF{#3}{\text{\textdblhyphen}}{\text{\textdblhyphen}_{#3}}}%
  \VTerm{#2}%
  ; #4%
}

%% GWEEK SPECIFIC

\NewDocumentCommand{\Gweek}{}{\textsc{Gweek}}

\NewDocumentCommand{\KW}{m}{\textsf{\textbf{#1}}}
\NewDocumentCommand{\GwExists}{}{\KW{exists}}
\NewDocumentCommand{\GwCase}{}{\KW{case}}
\NewDocumentCommand{\GwOf}{}{\KW{of}}
\NewDocumentCommand{\GwLet}{}{\KW{let}}
\NewDocumentCommand{\GwIn}{}{\KW{in}}
\NewDocumentCommand{\GwFail}{}{\KW{fail}}

%% MACHINE COMPONENTS

\NewDocumentCommand{\MComp}{}{\textsf{MComputation}}
\NewDocumentCommand{\MVal}{}{\textsf{MValue}}
\NewDocumentCommand{\SuspEnv}{}{\textsf{SuspEnv}}
\NewDocumentCommand{\LogicEnv}{}{\textsf{LogicEnv}}
\NewDocumentCommand{\Env}{}{\textsf{Env}}

%% OBSERVATIONAL PREORDER

\NewDocumentCommand{\ObsRelSymb}{}{
  \mathrel{%
    \ooalign{%
      \raise.270ex\hbox{$\sqsubset$}%
        \cr%
      \raise-.7ex\hbox{$\sim$}\cr%
    }%
  }
}
\NewDocumentCommand{\ObsApprox}{mm}{\CTerm{#1} \ObsRelSymb \CTerm{#2}}
\NewDocumentCommand{\ObsEquiv}{mm}{\CTerm{#1} \simeq \CTerm{#2}}

%% FUNCTION TYPES AND SUBSTITUTION

\NewDocumentCommand{\FnT}{mm}{#1 \to #2}
\NewDocumentCommand{\IsSubst}{O{\Gamma}mm}{#1 \vdash #2 : #3}
\NewDocumentCommand{\VSimSubst}{smm}{%
  \IfBooleanTF{#1}{\DelimPrn{\VTerm{#2}}}{\VTerm{#2}}\Meta{\DelimBrc{#3}}
}
\NewDocumentCommand{\SimSubC}{smm}{%
  \IfBooleanTF{#1}{\DelimPrn{\CTerm{#2}}}{\CTerm{#2}}\Meta{\DelimBrc{#3}}
}
\NewDocumentCommand{\Mgu}{m}{\textsf{mgu}(#1)}

%% STRATEGIES
\NewDocumentCommand{\BFS}{}{\textsc{bfs}}
\NewDocumentCommand{\DFS}{}{\textsc{dfs}}
\NewDocumentCommand{\IDDFS}{}{\textsc{iddfs}}
\NewDocumentCommand{\Fair}{}{\textsc{fair}}

%% ===== CBV CALCULUS =====

\definecolor{CBVGreen}{HTML}{467D5E}
\NewDocumentCommand{\CBV}{m}{{\color{CBVGreen}{#1}}}

% CBV typing judgment (single judgment)
\NewDocumentCommand{\IsCBV}{O{\Gamma}mm}{#1 \vdash \CBV{#2} : #3}

% CBV term constructors
\NewDocumentCommand{\CBVLam}{smom}{%
  \lambda #2\IfValueT{#3}{: #3}.\, \IfBooleanTF{#1}{\DelimPrn{#4}}{#4}
}
\NewDocumentCommand{\CBVApp}{smm}{%
  \IfBooleanTF{#1}{\DelimPrn{#2}}{#2}\;#3
}
\NewDocumentCommand{\CBVLet}{mmm}{%
  \textsf{let}\; #1 = #2 \;\textsf{in}\; #3
}
\NewDocumentCommand{\CBVFix}{mom}{%
  \textsf{rec}\DelimPrn{\IfValueTF{#2}{\DeclVar{#1}{#2}}{#1}.\, #3}
}
\NewDocumentCommand{\CBVIfz}{mmmm}{\textsf{ifz}(#1;\; #2;\; #3.\, #4)}
\NewDocumentCommand{\CBVMatch}{mmmmm}{\textsf{match}(#1;\; #2;\; #3, #4.\, #5)}
\NewDocumentCommand{\CBVSplit}{mmmm}{\textsf{split}(#1;\; #2, #3.\, #4)}
\NewDocumentCommand{\CBVCase}{mmmmm}{\textsf{case}(#1;\; #2.\, #3;\; #4.\, #5)}
\NewDocumentCommand{\CBVEquate}{mmom}{%
  #1%
  \mathbin{\IfNoValueTF{#3}{\text{\textdblhyphen}}{\text{\textdblhyphen}_{#3}}}%
  #2%
  ;\, #4%
}

% CBV translation brackets
\NewDocumentCommand{\Transl}{sm}{%
  \llbracket\IfBooleanTF{#1}{}{\,}#2\IfBooleanTF{#1}{}{\,}\rrbracket
}
