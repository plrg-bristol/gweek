add :: Nat -> Nat -> Nat
add n m = case m of
    Z -> n
  | S z -> S (add n z).

add3 :: Nat -> Nat -> Nat -> Nat
add3 a b c = add a (add b c).

revappend :: [Nat] -> [Nat] -> [Nat]
revappend xs ys = case xs of
    [] -> ys
  | (z:zs) -> revappend zs (z : ys).

pick :: [Nat] -> [Nat] -> [Nat]
pick skipped rest = case rest of
    [] -> fail
  | (x:xs) -> (x : revappend skipped xs)
              <> (pick (x : skipped) xs).

exists a :: Nat. exists b :: Nat. exists c :: Nat.
exists d :: Nat. exists e :: Nat. exists f :: Nat.
exists g :: Nat. exists h :: Nat. exists i :: Nat.
case pick [] [1,2,3,4,5,6,7,8,9] of [] -> fail | (a1:r1) ->
a1 =:= a.
case pick [] r1 of [] -> fail | (b1:r2) ->
b1 =:= b.
case pick [] r2 of [] -> fail | (c1:r3) ->
c1 =:= c.
add3 a b c =:= 15.
case pick [] r3 of [] -> fail | (d1:r4) ->
d1 =:= d.
case pick [] r4 of [] -> fail | (e1:r5) ->
e1 =:= e.
case pick [] r5 of [] -> fail | (f1:r6) ->
f1 =:= f.
add3 d e f =:= 15.
case pick [] r6 of [] -> fail | (g1:r7) ->
g1 =:= g.
case pick [] r7 of [] -> fail | (h1:r8) ->
h1 =:= h.
case pick [] r8 of [] -> fail | (i1:r9) ->
i1 =:= i.
add3 g h i =:= 15.
add3 a d g =:= 15.
add3 b e h =:= 15.
add3 c f i =:= 15.
add3 a e i =:= 15.
add3 c e g =:= 15.
[a, b, c, d, e, f, g, h, i].
