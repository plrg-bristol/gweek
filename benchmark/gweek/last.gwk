cat :: [Nat] -> [Nat] -> [Nat]
cat xs ys = case xs of
      [] -> ys
    | (x:rest) -> x : (cat rest ys).

last :: [Nat] -> Nat
last xs = exists ys :: [Nat]. exists y :: Nat.
    cat ys [y] =:= xs. y.

